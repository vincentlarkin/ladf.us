{
  "name": "ladf.us",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync:data": "node ./scripts/sync-district-data.mjs && node ./scripts/sync-service-directory.mjs && node ./scripts/sync-municipality-enhancements.mjs && node ./scripts/sync-representative-photos.mjs",
    "sync:services": "node ./scripts/sync-service-directory.mjs",
    "sync:municipalities": "node ./scripts/sync-municipality-enhancements.mjs",
    "sync:representatives": "node ./scripts/sync-representative-photos.mjs",
    "dev": "vite",
    "build": "vite build",
    "build:refresh": "npm run sync:data && npm run build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "vite": "^8.0.0"
  },
  "dependencies": {
    "@turf/boolean-point-in-polygon": "^7.3.4",
    "@turf/simplify": "^7.3.4",
    "leaflet": "^1.9.4",
    "shpjs": "^6.2.0"
  }
}
